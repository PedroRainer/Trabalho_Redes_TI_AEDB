# ========================
# 1. Stage: dependencies
# ========================
FROM mirror.gcr.io/library/node:22-alpine AS deps
WORKDIR /app

# Copia os arquivos de dependências
COPY package.json package-lock.json* ./

# Instala dependências de produção e dev (com versionamento travado)
RUN npm ci
RUN npm install --save-dev @types/ws
RUN npm install next@latest

# ========================
# 2. Stage: build
# ========================
FROM mirror.gcr.io/library/node:22-alpine AS build
WORKDIR /app

# Copia os módulos e código fonte
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Desativa telemetria
ENV NEXT_TELEMETRY_DISABLED=1

# Faz o build de produção
RUN npm run build

# ========================
# 3. Stage: run (produção)
# ========================
FROM mirror.gcr.io/library/node:22-alpine AS run
WORKDIR /app
ENV NODE_ENV=production

# Copia o build gerado
COPY --from=build /app/.next ./.next
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./
COPY --from=build /app/next.config.mjs ./

# 🔧 Inclui diretórios necessários em runtime
COPY --from=build /app/src ./src
COPY --from=build /app/pages ./pages


# Abre a porta do app
EXPOSE 3000

# Inicia o app em produção
CMD ["npm", "start"]
